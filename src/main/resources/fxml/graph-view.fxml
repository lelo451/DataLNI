<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lni.datalni.ui.GraphViewController"
      spacing="10.0">

    <HBox spacing="8.0" alignment="CENTER_LEFT">
        <Label text="Gráficos" styleClass="module-title"/>
        <TextField fx:id="searchField" promptText="Buscar título/descrição" prefWidth="240.0"/>
        <Button text="Buscar" onAction="#onSearch">
            <graphic><FontIcon iconLiteral="fas-search"/></graphic>
        </Button>
        <Button text="Atualizar" onAction="#onRefresh">
            <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="newGraphButton" text="Novo" onAction="#onNewGraph">
            <graphic><FontIcon iconLiteral="fas-plus"/></graphic>
        </Button>
        <Button fx:id="editGraphButton" text="Editar" onAction="#onEditGraph">
            <graphic><FontIcon iconLiteral="fas-edit"/></graphic>
        </Button>
        <Button fx:id="deleteGraphButton" text="Excluir" onAction="#onDeleteGraph">
            <graphic><FontIcon iconLiteral="fas-trash"/></graphic>
        </Button>
    </HBox>

    <TableView fx:id="graphTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="graphIdColumn" text="ID" prefWidth="70.0"/>
            <TableColumn fx:id="graphTitleColumn" text="Título" prefWidth="320.0"/>
            <TableColumn fx:id="graphDescriptionColumn" text="Descrição" prefWidth="420.0"/>
        </columns>
    </TableView>

    <HBox spacing="8.0" alignment="CENTER_LEFT">
        <Label text="Números (UEM) do gráfico selecionado" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="newDataNumberButton" text="Novo número" onAction="#onNewDataNumber">
            <graphic><FontIcon iconLiteral="fas-plus"/></graphic>
        </Button>
        <Button fx:id="editDataNumberButton" text="Editar" onAction="#onEditDataNumber">
            <graphic><FontIcon iconLiteral="fas-edit"/></graphic>
        </Button>
        <Button fx:id="deleteDataNumberButton" text="Excluir" onAction="#onDeleteDataNumber">
            <graphic><FontIcon iconLiteral="fas-trash"/></graphic>
        </Button>
    </HBox>

    <TableView fx:id="dataNumberTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dnMonthColumn" text="Mês" prefWidth="80.0"/>
            <TableColumn fx:id="dnYearColumn" text="Ano" prefWidth="90.0"/>
            <TableColumn fx:id="dnValueColumn" text="Valor" prefWidth="140.0"/>
            <TableColumn fx:id="dnClazzColumn" text="Classe" prefWidth="260.0"/>
        </columns>
    </TableView>

    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0"/>
    </padding>
</VBox>
