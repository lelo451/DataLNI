<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lni.datalni.ui.ProjectViewController"
      spacing="10.0">
    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0"/>
    </padding>

    <HBox spacing="8.0" alignment="CENTER_LEFT">
        <Label text="Projetos" styleClass="module-title"/>
        <TextField fx:id="searchField" promptText="Buscar título/coordenador/eprotocolo"
                   prefWidth="300.0"/>
        <Button text="Buscar" onAction="#onSearch"/>
        <Button text="Atualizar" onAction="#onRefresh"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="newButton" text="Novo" onAction="#onNew"/>
        <Button fx:id="editButton" text="Editar" onAction="#onEdit"/>
        <Button fx:id="deleteButton" text="Excluir" onAction="#onDelete"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="70.0"/>
            <TableColumn fx:id="titleColumn" text="Título" prefWidth="320.0"/>
            <TableColumn fx:id="coordinatorColumn" text="Coordenador" prefWidth="220.0"/>
            <TableColumn fx:id="eprotocolColumn" text="e-Protocolo" prefWidth="140.0"/>
            <TableColumn fx:id="odsColumn" text="ODS" prefWidth="260.0"/>
        </columns>
    </TableView>
</VBox>
